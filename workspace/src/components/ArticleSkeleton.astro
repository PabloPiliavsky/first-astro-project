---
import Card from './ui/Card.astro';
import VStack from './ui/VStack.astro';
import HStack from './ui/HStack.astro';
---

<Card class="h-full flex flex-col animate-pulse">
  <div class="h-44 w-full bg-slate-800/60"></div>
  <VStack gap="md" class="p-5 flex-1 justify-between">
    <VStack gap="sm">
      <HStack align="between">
        <div class="h-4 w-16 bg-slate-800 rounded"></div>
        <div class="h-3 w-12 bg-slate-800 rounded"></div>
      </HStack>
      <div class="h-5 bg-slate-800 rounded w-full"></div>
      <div class="h-5 bg-slate-800 rounded w-3/4"></div>
      <div class="h-3 bg-slate-800/60 rounded w-full mt-2"></div>
      <div class="h-3 bg-slate-800/60 rounded w-5/6"></div>
    </VStack>
    <HStack gap="sm" class="pt-3 border-t border-slate-800/60">
      <div class="w-6 h-6 rounded-full bg-slate-800"></div>
      <div class="h-3 w-24 bg-slate-800 rounded"></div>
    </HStack>
  </VStack>
</Card>

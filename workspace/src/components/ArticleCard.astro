---
import Card from './ui/Card.astro';
import HStack from './ui/HStack.astro';
import VStack from './ui/VStack.astro';
import Badge from './ui/Badge.astro';
import Text from './ui/Text.astro';
import type { DevToArticle } from '../types/article';

interface Props {
  article: DevToArticle;
}

const { article } = Astro.props;
---

<Card variant="hoverable" class="h-full flex flex-col">
  {article.cover_image ? (
    <img 
      src={article.cover_image} 
      alt={article.title} 
      class="h-44 w-full object-cover border-b border-slate-800" 
      loading="lazy"
    />
  ) : (
    <VStack align="center" class="h-44 w-full bg-gradient-to-br from-indigo-950 to-slate-900 justify-center border-b border-slate-800 p-4 text-center">
      <Text variant="muted" class="font-mono text-indigo-400 font-semibold">{article.title}</Text>
    </VStack>
  )}

  <VStack gap="md" class="p-5 flex-1 justify-between">
    <VStack gap="sm">
      <HStack align="between" gap="xs">
        <Badge variant="indigo">
          {article.tag_list[0] || 'Dev.to'}
        </Badge>
        <Text variant="muted" class="font-mono">
          {article.readable_publish_date}
        </Text>
      </HStack>

      <Text as="h3" variant="h3" class="line-clamp-2 hover:text-indigo-400 transition-colors">
        <a href={article.url} target="_blank" rel="noopener noreferrer">
          {article.title}
        </a>
      </Text>

      <Text variant="body" class="line-clamp-3 leading-relaxed">
        {article.description}
      </Text>
    </VStack>

    <HStack gap="sm" class="pt-3 border-t border-slate-800/60">
      {article.user?.profile_image_90 && (
        <img 
          src={article.user.profile_image_90} 
          alt={article.user.name} 
          class="w-6 h-6 rounded-full border border-slate-700"
        />
      )}
      <Text variant="body" class="font-medium text-slate-300 truncate">
        {article.user?.name || 'Autor Desconocido'}
      </Text>
    </HStack>
  </VStack>
</Card>

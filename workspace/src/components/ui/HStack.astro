---
import './HStack.css';

interface Props {
  gap?: 'none' | 'xs' | 'sm' | 'md' | 'lg' | 'xl';
  align?: 'start' | 'center' | 'end' | 'between' | 'around';
  class?: string;
}

const { gap = 'md', align = 'center', class: className = '' } = Astro.props;

const gapMap = {
  none: 'gap-0',
  xs: 'gap-1',
  sm: 'gap-2',
  md: 'gap-4',
  lg: 'gap-6',
  xl: 'gap-8',
};

const alignMap = {
  start: 'flex-row items-center justify-start',
  center: 'flex-row items-center justify-center',
  end: 'flex-row items-center justify-end',
  between: 'flex-row items-center justify-between',
  around: 'flex-row items-center justify-around',
};
---

<div class:list={['h-stack', gapMap[gap], alignMap[align], className]}>
  <slot />
</div>

---
import './Text.css';

export interface Props {
  as?: 'h1' | 'h2' | 'h3' | 'h4' | 'p' | 'span';
  variant?: 'h1' | 'h2' | 'h3' | 'body' | 'muted' | 'lead';
  class?: string;
}

const { as: Tag = 'p', variant = 'body', class: className = '' } = Astro.props;
---

<Tag class:list={['ui-text', `ui-text--${variant}`, className]}>
  <slot />
</Tag>

---
import './VStack.css';

interface Props {
  gap?: 'none' | 'xs' | 'sm' | 'md' | 'lg' | 'xl';
  align?: 'start' | 'center' | 'end' | 'stretch';
  class?: string;
}

const { gap = 'md', align = 'stretch', class: className = '' } = Astro.props;

const gapMap = {
  none: 'gap-0',
  xs: 'gap-1',
  sm: 'gap-2',
  md: 'gap-4',
  lg: 'gap-6',
  xl: 'gap-8',
};

const alignMap = {
  start: 'items-start',
  center: 'items-center',
  end: 'items-end',
  stretch: 'items-stretch',
};
---

<div class:list={['v-stack', gapMap[gap], alignMap[align], className]}>
  <slot />
</div>

---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "TechPulse | Agregador de Noticias Dev.to",
  description = "Obtén las últimas novedades de desarrollo web y tecnología directamente de Dev.to",
} = Astro.props;
---

<!doctype html>
<html lang="es" class="h-full bg-slate-950 text-slate-100">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body
    class="min-h-full flex flex-col font-sans antialiased bg-slate-950 text-slate-100"
  >
    <header
      class="sticky top-0 z-50 border-b border-slate-800 bg-slate-950/80 backdrop-blur-md"
    >
      <div
        class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between"
      >
        <a
          href="/"
          class="flex items-center gap-2 text-xl font-bold tracking-tight text-white hover:text-indigo-400 transition-colors"
        >
          <span
            class="bg-indigo-600 text-white px-2 py-0.5 rounded text-sm font-mono"
            >DEV</span
          >
          <span>TechPulse</span>
        </a>
        <nav class="flex items-center gap-4 text-sm font-medium text-slate-400">
          <a href="/" class="hover:text-white transition-colors">Inicio</a>
          <a
            href="https://dev.to"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-white transition-colors">Dev.to API</a
          >
        </nav>
      </div>
    </header>

    <div class="flex-1">
      <slot />
    </div>

    <footer
      class="border-t border-slate-800 bg-slate-950 py-6 text-center text-xs text-slate-500"
    >
      <p>Construido con Astro v4, Tailwind CSS v4 y Dev.to API.</p>
    </footer>
  </body>
</html>
